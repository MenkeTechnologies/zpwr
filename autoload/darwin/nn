# -*- mode: sh -*-
# vim: set ft=sh:
function nn(){

        local title msg

        if [[ -z "$2" ]];then
            zpwrLogConsoleErr "usage: nn TITLE MESSAGE..." &&
            return 1
        fi

        title="$1"
        msg="$2"
        echo "display notification \"$msg\" with title \"$title\"" |
            osascript
    }

nn "$@"

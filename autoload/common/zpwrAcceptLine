# -*- mode: sh -*-
# vim: set ft=sh:

function zpwrAcceptLine () {

    builtin emulate -L zsh
    setopt noshwordsplit extendedglob

    local pane mywords line command cmd Aliases args prefix cmdstr value
    local _expanded _datestamp

    # inline alias expansion check — avoids fork+subshell on every Enter
    unset 'functions[_expand-aliases]'
    functions[_expand-aliases]=$BUFFER
    _expanded=${functions[_expand-aliases]#$'\t'}
    unset 'functions[_expand-aliases]'

    # use strftime builtin instead of $(date) fork
    # zsh/datetime already loaded at init time
    strftime -s _datestamp '%Y-%m-%d %H:%M:%S'

    if ! [[ $_expanded = zc* ]]; then
        ZPWR_CONVEY_NAME="TTY:${TTY} PID:${$} CMD:$BUFFER PWD:${PWD} DATE:$_datestamp"
        zc-rename $ZPWR_CONVEY_NAME &>/dev/null
        ZPWR_CONVEY_LAST_CMD=$BUFFER
    else
        if [[ -z $ZPWR_CONVEY_LAST_CMD ]]; then
            ZPWR_CONVEY_LAST_CMD="-zsh $-"
        fi

        ZPWR_CONVEY_NAME="TTY:${TTY} PID:${$} CMD: $ZPWR_CONVEY_LAST_CMD PWD:${PWD} DATE:$_datestamp"
        zc-rename $ZPWR_CONVEY_NAME &>/dev/null
    fi

    ZPWR_WILL_CLEAR=false
    if [[ $ZPWR_SEND_KEYS_FULL == false ]]; then
        zpwrKeyClear
    else
        if ! [[ $BUFFER == *zpwrStopSend* ]]; then
            for pane in ${(Az)${(s@,@)ZPWR_SEND_KEYS_PANE}}; do
                tmux send-keys -t $pane "C-m"
            done
        else
            for pane in ${(Az)${(s@,@)ZPWR_SEND_KEYS_PANE}}; do
                tmux send-keys -t $pane "C-u"
            done
        fi
    fi

    #do we want to clear the screen and run ls after we exec the current line?
    # ZPWR_CMDS_THAT_MODIFY_FILES defined in env/.zpwr_env.sh

    zpwrExpandParseWords "$BUFFER"

      if [[ $ZPWR_VARS[cachedRegexMatched] == true ]]; then
        cmdstr=${(QL)ZPWR_VARS[cachedRegexMatch]}
        prefix=${(QL)ZPWR_VARS[cachedParserPrefix]}

        mywords=( ${(z)cmdstr} )

        for command in ${ZPWR_CMDS_THAT_MODIFY_FILES[@]}; do
            # match touch t
            # NOT touchtest t

            if [[ ${cmdstr} == ${command}([^[:alnum:]_]*|) ]]; then
                ZPWR_WILL_CLEAR=true
                zpwrLogDebug "found '$command' in '$BUFFER' with matches '$match'"
                break
            fi
        done

        # sudo =iftop fails so remove =
        cmd=${mywords[1]#=}

        #so sudo -E env ping uses grc overalias of ping
        if zpwrCommandExists grc; then

            args=( "${mywords[2,-1]}" )

            if [[ $prefix == (*sudo*|*env*|*nice*|*time*) ]]; then

                value="${aliases[$cmd]}"
                if [[ $value == grc([^[:alnum:]_]*|) ]]; then
                    print -srn -- "$BUFFER"
                    BUFFER="$ZPWR_FULL_SUDO $value ${args[@]}"
                    echo
                    eval "$BUFFER"
                    BUFFER=""
                    zle .accept-line
                    return 0
                fi
            fi
        fi
    else
        # single word: parser skips single-word input, so set cmd here
        mywords=( ${(z)BUFFER} )
        cmd=${mywords[1]#=}
    fi

    # prevent global alias in first position from expanding
    local skipExpand=false
    if [[ -z "$BUFFER" ]]; then
        zle .accept-line
        return 0
    fi
    if [[ -n ${galiases[$cmd]} ]];then
        skipExpand=true
        if [[ -z "$ZPWR_GLOBAL_ALIAS_PREFIX" ]]; then
            if [[ -n ${aliases[$cmd]} ]];then
                # non global alias - expand regular alias to prevent global alias expansion
                line="${aliases[$cmd]}"
                # zsh pattern match avoids fork+pipe of grep
                if [[ $line == *"'"* ]]; then
                    BUFFER="${line:1:-1} $mywords[2,$]"
                else
                    BUFFER="$line $mywords[2,$]"
                fi
            else
                # function
                BUFFER="\\$mywords"
            fi
        else
            if [[ -n $prefix ]]; then
                BUFFER="$prefix \\$cmdstr"
            else
                BUFFER="\\$mywords"
            fi
        fi
    fi


    if [[ $ZPWR_EXPAND_PRE_EXEC == true && $skipExpand == false ]]; then
        CURSOR=${#BUFFER}
        zpwrExpandSupernaturalSpace "${ZPWR_VARS[ENTER_KEY]}"
    fi

    zle .accept-line
    # leaky $ZPWR_DEFAULT_OMZ_THEME theme so reset ANSI escape sequences
    printf "\x1b[0m"
}

zpwrAcceptLine "$@"

# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrEmacsAllEdit(){

    if ! zpwrExists emacs; then
        zpwrLogConsoleErr "emacs must exist"
        return 1
    fi

    BUFFER="$(zpwrFzvimAll)"
    if [[ -z "$BUFFER" ]]; then
        return
    fi
    BUFFER="$ZPWR_EMACS_CLIENT $BUFFER"
    zpwrLogDebug "builtin cd $ZPWR"
    builtin cd "$ZPWR" || {
        zpwrLogConsoleErr "cannot cd to $ZPWR"
        return 1
    }

    BUFFER="$BUFFER; zpwrClearList; zpwrIsGitDir && git diff HEAD"
    zpwrLogDebug "$BUFFER"
    print -s -- "$BUFFER"
    eval "$BUFFER"
}

zpwrEmacsAllEdit "$@"

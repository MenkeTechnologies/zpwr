# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrEmacsEmacsConfig(){

    builtin cd "$ZPWR" || {
        zpwrLogConsoleErr "cannot cd to $ZPWR"
        return 1
    }
    ${=ZPWR_EMACS_CLIENT} \
    "$ZPWR_INSTALL/.spacemacs" \
    "$ZPWR_INSTALL/emacs/snippets/"*-mode/*
    zpwrClearList
    zpwrIsGitDir && git diff HEAD
}

zpwrEmacsEmacsConfig "$@"

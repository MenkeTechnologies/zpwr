        # ‚ĒÄ‚ĒÄ SCANLINE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if (( scanline_cooldown > 0 )); then
            (( scanline_cooldown-- ))
        elif (( RANDOM % 250 == 0 )); then
            local -i sy
            for (( sy=1; sy<=lines-3; sy+=2 )); do
                printf '\033[%d;1H\033[7;32m%*s\033[0m' $sy $cols ''
                sleep 0.006
                printf '\033[%d;1H%*s' $sy $cols ''
            done
            scanline_cooldown=120
        fi

        # ‚ĒÄ‚ĒÄ FIGLET CHAOS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if (( figlet_cooldown > 0 )); then
            (( figlet_cooldown-- ))
        elif (( RANDOM % 150 == 0 && $+commands[figlet] )); then
            local fig_font="${chaos_fonts[$((RANDOM % ${#chaos_fonts} + 1))]}"
            local fig_word="${chaos_words[$((RANDOM % ${#chaos_words} + 1))]}"
            local fig_color="${chaos_colors[$((RANDOM % ${#chaos_colors} + 1))]}"
            local fig_out
            fig_out=$(figlet -f "$fig_font" "$fig_word" 2>/dev/null)

            if [[ -n "$fig_out" ]]; then
                local -i fy=$(( RANDOM % (lines / 2) + 2 )) fx
                local fline
                while IFS= read -r fline; do
                    fx=$(( (cols - ${#fline}) / 2 ))
                    (( fx < 1 )) && fx=1
                    (( fy > lines - 4 )) && break
                    printf '\033[%d;%dH\033[%sm%s\033[0m' $fy $fx "$fig_color" "$fline"
                    (( fy++ ))
                done <<< "$fig_out"

                sleep 0.3

                # dissolve
                fy=$(( fy - $(echo "$fig_out" | wc -l) ))
                while IFS= read -r fline; do
                    fx=$(( (cols - ${#fline}) / 2 ))
                    (( fx < 1 )) && fx=1
                    (( fy > lines - 4 )) && break
                    printf '\033[%d;%dH%*s' $fy $fx ${#fline} ''
                    (( fy++ ))
                done <<< "$fig_out"
            fi
            figlet_cooldown=80
        fi

        # ‚ĒÄ‚ĒÄ PULSE EVENT ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if (( pulse_cooldown > 0 )); then
            (( pulse_cooldown-- ))
        elif (( RANDOM % 100 == 0 )); then
            local pmsg="${pulse_msgs[$((RANDOM % n_pulses + 1))]}"
            local -i py=$(( RANDOM % (lines - 6) + 2 ))
            local -i px=$(( (cols - ${#pmsg}) / 2 ))
            (( px < 1 )) && px=1

            printf '\033[%d;1H\033[7;36m%*s\033[0m' $py $cols ''
            printf '\033[%d;%dH\033[1;37;46m %s \033[0m' $py $px "$pmsg"
            sleep 0.35
            printf '\033[%d;1H%*s' $py $cols ''
            pulse_cooldown=50
        fi

        # ‚ĒÄ‚ĒÄ TICKER ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if (( frame % 2 == 0 )); then
            local -i tline=$(( lines - 2 ))
            local visible=""
            if (( ticker_pos < ticker_len )); then
                visible="${ticker_text:$ticker_pos:$cols}"
            fi
            printf '\033[%d;1H\033[0;33;40m%-*s\033[0m' $tline $cols "$visible"
            (( ticker_pos++ ))
            if (( ticker_pos > ticker_len + 10 )); then
                ticker_pos=0
                (( ticker_idx++ ))
                (( ticker_idx > ${#ticker_msgs} )) && ticker_idx=1
                ticker_text="${ticker_msgs[$ticker_idx]}"
                ticker_len=${#ticker_text}
            fi
        fi

        # ‚ĒÄ‚ĒÄ HUD ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        if (( frame % 10 == 0 )); then
            local -i up_s=$SECONDS up_m up_h
            up_h=$(( up_s / 3600 ))
            up_m=$(( (up_s % 3600) / 60 ))
            up_s=$(( up_s % 60 ))

            local sig_bar=""
            local -i sf=$(( frame % 20 )) si
            for (( si=0; si<10; si++ )); do
                if (( si <= sf / 2 )); then sig_bar+="‚Ėą"; else sig_bar+="‚ĖĎ"; fi
            done

            printf '\033[%d;1H\033[1;32;40m ‚ö° ZPWR' $(( lines - 1 ))
            printf '  \033[2;32m//\033[1;32;40m  %dv %da %df %dp %dr' $n_verbs $n_aliases $n_funcs $n_params $n_repos
            printf '  \033[2;32m//\033[1;35;40m  %dauto %dscr %dcomp' $n_autoloads $n_scripts $n_comps
            printf '  \033[2;32m//\033[1;36;40m  %s' "$sig_bar"
            printf '%*s\033[0m' $(( cols - 80 )) ''

            printf '\033[%d;1H\033[2;36;40m ‚Ėł f%05d' $lines $frame
            printf '  //  %02d:%02d:%02d' $up_h $up_m $up_s
            printf '  //  %dx%d' $cols $lines
            printf '  //  %d commits' $n_commits
            printf '  //  %d pages' $n_pages
            printf '  //  [q] quit'
            printf '%*s\033[0m' $(( cols - 72 )) ''
        fi

        sleep $(( 0.08 / speed ))
    done
}

zpwrMatrix "$@"

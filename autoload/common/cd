# -*- mode: sh -*-
# vim: set ft=sh:

function cd(){

    # builtin is necessary here to distinguish
    # bt function name and builtin cd command
    # don't want to recursively call this function
    builtin cd "$@" >/dev/null || return 1
    if [[ $ZPWR_AUTO_LS_CD == true ]]; then
        if [[ -t 0  && -t 1 ]]; then
            zpwrClearList || true
        fi
    fi
}

cd "$@"

# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrEmacsScriptEdit(){

    if ! zpwrExists emacs; then
        zpwrLogConsoleErr "emacs must exist"
        return 1
    fi

    BUFFER="$(zpwrFzvimScript)"
    if [[ -z "$BUFFER" ]]; then
        return
    fi
    BUFFER="$ZPWR_EMACS_CLIENT $BUFFER"
    zpwrLogDebug "builtin cd $ZPWR_SCRIPTS"
    builtin cd "$ZPWR_SCRIPTS" || {
        zpwrLogConsoleErr "cannot cd to $ZPWR_SCRIPTS"
        return 1
    }

    BUFFER="$BUFFER; zpwrClearList; zpwrIsGitDir && git diff HEAD"
    zpwrLogDebug "$BUFFER"
    print -s -- "$BUFFER"
    eval "$BUFFER"
}

zpwrEmacsScriptEdit "$@"

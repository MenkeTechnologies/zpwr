# -*- mode: sh -*-
# vim: set ft=sh:
function lcm(){

    if ! zpwrIsGitDir; then
        zpwrLogConsoleNotGit
        return 1
    fi
    local msg tag

    msg="$(git log -1 --pretty='%s')"
    tag="$(git tag --sort=-v:refname -l | sed 1q)"

    print -rz -- "git tag -fam '$msg' $tag && git push -f origin --tags"
}

lcm "$@"

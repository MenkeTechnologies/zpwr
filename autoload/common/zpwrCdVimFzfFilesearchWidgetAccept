# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrVimFzfFilesearchWidgetAccept(){

    local f

    f="$(zpwrFzfFileSearch)"

    if [[ -n "$f" ]]; then
        zle .kill-whole-line
        BUFFER="EDITOR='$ZPWR_ZEMACS' zpwr vimcd $f"
        zpwrLogDebug "$BUFFER"
        zle .accept-line
    fi
}

zpwrVimFzfFilesearchWidgetAccept "$@"

# -*- mode: sh -*-
# vim: set ft=sh:

function zpwrConvertToRelPath(){
    while read; do
        zpwrRelPath $REPLY
    done
}

# list files with fd, falling back to find when fd is not installed.
# callers pass fd flags + regex pattern first and the search path last, so the
# find fallback keys off the last argument.
function zpwrFdOrFind(){
    if zpwrExists fd; then
        ${=ZPWR_FD} "$@"
    else
        command find "${@[-1]}" -type f -follow 2>/dev/null
    fi
}


function zpwrFzfFileSearch(){

    emulate -LR zsh
    local filter=cat top noslash

    if [[ -n "$1" ]]; then
        filter="$1"
    fi

    if zpwrIsGitDir; then
        top=$(git rev-parse --show-toplevel)
        if [[ $PWD == $top ]]; then
            if git check-ignore -q . &>/dev/null; then
                zpwrFdOrFind --no-ignore . ./ 2>/dev/null
            else
                zpwrFdOrFind . ./ 2>/dev/null
            fi
        else
            if git check-ignore -q . &>/dev/null; then
                zpwrFdOrFind --no-ignore . $top 2>/dev/null
            else
                zpwrFdOrFind . $top 2>/dev/null
            fi | zpwrConvertToRelPath
        fi
    else
        zpwrFdOrFind . ./ 2>/dev/null | cut -c3-
    fi | ${=filter} |
        eval "$ZPWR_FZF -m --border $FZF_CTRL_T_OPTS" |
        stryke -ne 'chomp $_; print "\"$_\" "'
}

zpwrFzfFileSearch "$@"

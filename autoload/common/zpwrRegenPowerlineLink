# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrRegenPowerlineLink(){
    # Link the powerliners config tree ($ZPWR_INSTALL/.config/powerline) into
    # $XDG_CONFIG_HOME so powerline / powerline-render / powerline-daemon find
    # the zpwr theme + colorscheme. Without this link powerline falls back to
    # its baked-in 5-segment default theme.
    #
    # The powerline binaries themselves ship via the homebrew tap, not cargo.

    local configHome powerlineDir dest

    configHome="${XDG_CONFIG_HOME:-$HOME/.config}"
    powerlineDir="$ZPWR_INSTALL/.config/powerline"
    dest="$configHome/powerline"

    if [[ ! -d "$powerlineDir" ]]; then
        zpwrLogConsoleErr "no powerline config tree at $powerlineDir"
        return 1
    fi

    test -d "$configHome" || mkdir -p "$configHome"

    # A real directory here would make ln nest the link inside it.
    if [[ -d "$dest" && ! -L "$dest" ]]; then
        zpwrPrettyPrint "Backing up $dest to $dest.bak"
        command rm -rf "$dest.bak"
        command mv "$dest" "$dest.bak"
    fi

    zpwrPrettyPrint "Linking $powerlineDir to $dest"
    echo ln -sfn "$powerlineDir" "$dest"
    ln -sfn "$powerlineDir" "$dest"

    if zpwrCommandExists powerline-daemon; then
        zpwrPrettyPrint "Restarting powerline-daemon"
        command powerline-daemon --kill &>/dev/null
        command powerline-daemon -q &>/dev/null
    fi
}

zpwrRegenPowerlineLink "$@"

# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrRegenPowerlineLink(){
    # Refresh the powerliners install (Rust port of powerline-status).
    # Replaces the legacy "regen the ~/.tmux/powerline → site-packages
    # symlink" workflow now that powerline / powerline-daemon /
    # powerline-config / powerline-render are first-class cargo binaries
    # on PATH at $HOME/.cargo/bin/.
    if ! zpwrCommandExists cargo; then
        zpwrLogConsoleErr 'cargo not found; install rustup first'
        return 1
    fi
    zpwrPrettyPrint "Reinstalling powerliners via cargo"
    command cargo install --force powerliners || {
        zpwrLogConsoleErr 'cargo install --force powerliners failed'
        return 1
    }
    command tmux source-file "$ZPWR_TMUX/init.conf" &>> "$ZPWR_LOGFILE"
}

zpwrRegenPowerlineLink "$@"

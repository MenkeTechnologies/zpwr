# -*- mode: sh -*-
# vim: set ft=sh:
function j(){

    if [[ -z "$1" ]]; then
        zpwrLogConsoleErr "usage: j <dir/file>"
        return 1
    fi

    local file

    for file;do
        dirname="$(dirname $file)"
        [[ "$dirname" != . ]] && command mkdir -p "$dirname"
        touch "$file"
    done

    # Only drop into the editor interactively; in scripts/CI/pipes stdin is not
    # a tty, and launching vim/zmax there blocks forever with no controlling
    # terminal. An if-block (not `&&`) keeps the exit status 0 when skipped.
    if [[ -t 0 ]]; then
        "${ZPWR_ZMAX:-vim}" "$@"
    fi
}

j "$@"

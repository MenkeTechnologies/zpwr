# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrCdUp(){

    local cdstr
    if [[ -z $1 ]]; then
        cd .. || {
            zpwrLogConsoleErr "cannot cd .."
            return 1
        }
    else
        for (( i = 0; i < $1; ++i )); do
            cdstr+="../"
        done
        cd "$cdstr" || return 1
    fi
}

zpwrCdUp "$@"

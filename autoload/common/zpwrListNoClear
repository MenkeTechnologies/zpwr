# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrListNoClear () {

    if zpwrCommandExists eza; then
        if [[ -t 0 ]]; then
            eval "$ZPWR_EXA_COMMAND"
        elif : < /dev/tty 2>/dev/null; then
            eval "$ZPWR_EXA_COMMAND" < /dev/tty
        else
            eval "$ZPWR_EXA_COMMAND"
        fi
        return 0
    fi

    if [[ "$ZPWR_OS_TYPE" == darwin ]]; then
        if zpwrCommandExists grc; then
            grc -c "$HOME/conf.gls" gls \
            -iFlhA --color=always
        else
            ls -iFlhAO
        fi
    else
        if zpwrCommandExists grc; then
            grc -c "$HOME/conf.gls" \
            ls -iFlhA --color=always
        else
            ls -ifhlA
        fi
    fi
}

zpwrListNoClear "$@"

# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrFzfEnvVerbEdit(){

    local num sel

    if [[ ! -s "$ZPWR_ENV_KEY_FILE" ]]; then
        zpwrLogDebug "regenerating keys for $ZPWR_LOCAL_ENV"
        zpwrRegenSearchEnv
    fi
    if [[ ! -s "$ZPWR_ENV_VALUE_FILE" ]]; then
        zpwrLogDebug "regenerating values for $ZPWR_LOCAL_ENV"
        zpwrRegenSearchEnv
    fi
    if [[ ! -s "$ZPWR_ENV_IDX_FILE" ]]; then
        zpwrLogDebug "regenerating idx for $ZPWR_LOCAL_ENV"
        zpwrRegenSearchEnv
    fi

    sel=$(awk '{print $2}' "$ZPWR_ENV_KEY_FILE" |
        eval "$ZPWR_FZF -m --border $FZF_ENV_OPTS")

    if [[ -n "$sel" ]]; then
        print -zr -- "$sel"
    fi
}

zpwrFzfEnvVerbEdit "$@"

# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrCatNvimOrVimInfo() {

    local file

    if [[ $ZPWR_VIM == *nvim* ]]; then
        file="$ZPWR_NVIMINFO"
        test -e "$file" || touch "$file"
        cat "$file"
    else
        file="$HOME/.viminfo"
        test -e "$file" || touch "$file"
        tac "$file"
    fi

    # Fold in zmax recents too. zmax writes ~/.zmax/.zmaxinfo in the exact
    # viminfo format, so its `> path` blocks are harvested by the same downstream
    # extractor as Vim's — opening a file in zmax surfaces it in the pickers.
    if [[ -f $ZPWR_ZMAXINFO ]]; then
        tac "$ZPWR_ZMAXINFO"
    fi
}

zpwrCatNvimOrVimInfo "$@"

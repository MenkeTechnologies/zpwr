# -*- mode: sh -*-
# vim: set ft=sh:
function zpwrWizard(){

    builtin emulate -L zsh
    setopt extendedglob
    builtin zmodload zsh/datetime

    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    local K=$'\033[K' UL=$'\033[4m'

    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        print ""
        print " ${C}██╗    ██╗██╗███████╗ █████╗ ██████╗ ██████╗${N}"
        print " ${C}██║    ██║██║╚══███╔╝██╔══██╗██╔══██╗██╔══██╗${N}"
        print " ${M}██║ █╗ ██║██║  ███╔╝ ███████║██████╔╝██║  ██║${N}"
        print " ${M}██║███╗██║██║ ███╔╝  ██╔══██║██╔══██╗██║  ██║${N}"
        print " ${C}╚███╔███╔╝██║███████╗██║  ██║██║  ██║██████╔╝${N}"
        print " ${C} ╚══╝╚══╝ ╚═╝╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═════╝${N}"
        print " ${D}┌──────────────────────────────────────────────────────────────────────┐${N}"
        print " ${D}│${N} ${G}STATUS: ONLINE${N}  ${D}//${N} ${C}SIGNAL: ${G}████████${D}░░${N}  ${D}//${N} ${M}WIZARD${N}                   ${D}│${N}"
        print " ${D}└──────────────────────────────────────────────────────────────────────┘${N}"
        print "  ${D}>> INTERACTIVE TUTORIAL SYSTEM // GUIDED TOUR <<${N}"
        print ""
        print ""
        print "  Walk through all zpwr functionality with guided tutorials."
        print "  Sequential pages with navigation, examples, and tips."
        print ""
        print "  ${B}USAGE:${N} zpwr wizard ${D}[OPTIONS] [PAGE]${N}"
        print ""
        print "  ${D}── OPTIONS ──────────────────────────────────────────────────────────${N}"
        print "  ${C}-h, --help${N}                                       ${D}// Show this help${N}"
        print "  ${C}-t, --toc${N}                                        ${D}// Show table of contents${N}"
        print "  ${C}PAGE${N}                                             ${D}// Jump to page number or name${N}"
        print ""
        print "  ${D}── NAVIGATION ───────────────────────────────────────────────────────${N}"
        print "  ${C}n/enter${N}                                          ${D}// Next page${N}"
        print "  ${C}p${N}                                                ${D}// Previous page${N}"
        print "  ${C}t${N}                                                ${D}// Table of contents${N}"
        print "  ${C}1-9${N}                                              ${D}// Jump to chapter${N}"
        print "  ${C}q${N}                                                ${D}// Quit${N}"
        print ""
        print "  ${D}── EXAMPLES ─────────────────────────────────────────────────────────${N}"
        print "  ${C}zpwr wizard${N}                                      ${D}// start from beginning${N}"
        print "  ${C}zpwr wizard --toc${N}                                ${D}// show table of contents${N}"
        print "  ${C}zpwr wizard 5${N}                                    ${D}// jump to page 5${N}"
        print ""
        return 0
    fi

    # ── PAGE DEFINITIONS ──────────────────────────────────────
    # each page is a function that prints content
    local -i total_pages=12 current_page=1
    local key

    _wiz_header() {
        printf '\033[H\033[2J'
        print ""
        print " ${C}██╗    ██╗██╗███████╗ █████╗ ██████╗ ██████╗${N}"
        print " ${C}██║    ██║██║╚══███╔╝██╔══██╗██╔══██╗██╔══██╗${N}"
        print " ${M}██║ █╗ ██║██║  ███╔╝ ███████║██████╔╝██║  ██║${N}"
        print " ${M}██║███╗██║██║ ███╔╝  ██╔══██║██╔══██╗██║  ██║${N}"
        print " ${C}╚███╔███╔╝██║███████╗██║  ██║██║  ██║██████╔╝${N}"
        print " ${C} ╚══╝╚══╝ ╚═╝╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═════╝${N}"
        print " ${D}┌──────────────────────────────────────────────────────────────────────┐${N}"
        print " ${D}│${N} ${G}PAGE $1/${total_pages}${N}  ${D}//${N} ${C}$2${N}                                          ${D}│${N}"
        print " ${D}└──────────────────────────────────────────────────────────────────────┘${N}"
        print ""
    }

    _wiz_footer() {
        print ""
        print "  ${D}──────────────────────────────────────────────────────────────────────${N}"
        print "  ${C}[n]${N}ext  ${C}[p]${N}rev  ${C}[t]${N}oc  ${C}[1-9]${N} jump  ${C}[q]${N}uit"
        print -n "  ${D}>>>${N} "
    }

    _wiz_toc() {
        _wiz_header "TOC" "TABLE OF CONTENTS"
        print "  ${C}── ZPWR GUIDED TOUR ───────────────────────────────────────────────${N}"
        print ""
        print "  ${B}CHAPTER 1: GETTING STARTED${N}"
        print "    ${C} 1.${N} Welcome to ZPWR                        ${D}// overview & philosophy${N}"
        print "    ${C} 2.${N} Navigation & Shortcuts                  ${D}// cd, z, home, paths${N}"
        print ""
        print "  ${B}CHAPTER 2: DAILY WORKFLOW${N}"
        print "    ${C} 3.${N} Git Integration                         ${D}// 58 git verbs${N}"
        print "    ${C} 4.${N} Editor Integration                      ${D}// vim + emacs (57 verbs)${N}"
        print "    ${C} 5.${N} Search & Discovery                      ${D}// fzf, grep, locate${N}"
        print ""
        print "  ${B}CHAPTER 3: SHELL OPTIMIZATION${N}"
        print "    ${C} 6.${N} Startup Performance                     ${D}// bench, flame, top${N}"
        print "    ${C} 7.${N} Health & Diagnostics                    ${D}// doctor, deps, trace${N}"
        print "    ${C} 8.${N} Usage Analytics                         ${D}// funcrank, aliasrank${N}"
        print ""
        print "  ${B}CHAPTER 4: ADVANCED FEATURES${N}"
        print "    ${C} 9.${N} Environment Snapshots                   ${D}// snapshot, restore${N}"
        print "    ${C}10.${N} Monitoring & Automation                 ${D}// watch, replay, taillog${N}"
        print "    ${C}11.${N} Build & Maintenance                     ${D}// recompile, regen, clean${N}"
        print ""
        print "  ${B}CHAPTER 5: MASTERY${N}"
        print "    ${C}12.${N} The Full Arsenal                        ${D}// 408 verbs, tips & tricks${N}"
        print ""
        _wiz_footer
    }

    _wiz_page1() {
        _wiz_header "1" "WELCOME TO ZPWR"
        print "  ${B}${C}What is ZPWR?${N}"
        print ""
        print "  ZPWR is a complete terminal operating system built on zsh, tmux, and"
        print "  vim/neovim. It's not a plugin manager or a theme — it's an integrated"
        print "  environment with ${C}${#ZPWR_VERBS} commands${N}, ${C}${#functions} functions${N}, and ${C}${#aliases} aliases${N}."
        print ""
        print "  ${B}${M}Core Components:${N}"
        print "  ${D}//${N} ${B}zsh${N}         shell with instant prompt, turbo plugin loading"
        print "  ${D}//${N} ${B}tmux${N}        multiplexer with vim-tmux code execution"
        print "  ${D}//${N} ${B}vim/nvim${N}    editor with $(command ls ~/.vim/bundle/ 2>/dev/null | wc -l | tr -d ' ') plugins"
        print "  ${D}//${N} ${B}zinit${N}       deferred plugin loading for fast startup"
        print "  ${D}//${N} ${B}p10k${N}        instant prompt in ${G}${ZPWR_VARS[promptTimeMs]}s${N}"
        print "  ${D}//${N} ${B}fzf${N}         fuzzy finding everywhere"
        print ""
        print "  ${B}${M}Quick Start:${N}"
        print "  ${C}zpwr${N}                    ${D}// see all available verbs${N}"
        print "  ${C}zpwr <tab>${N}              ${D}// fuzzy-complete any verb${N}"
        print "  ${C}zpwr help${N}               ${D}// same as this wizard${N}"
        print "  ${C}zpwr about${N}              ${D}// show the zpwr banner${N}"
        print "  ${C}zpwr environmentcounts${N}  ${D}// show env statistics${N}"
        _wiz_footer
    }

    _wiz_page2() {
        _wiz_header "2" "NAVIGATION & SHORTCUTS"
        print "  ${B}${C}Moving Around:${N}"
        print ""
        print "  ${D}//${N} ${C}zpwr forward <dir>${N}     ${D}// cd forward into a subdirectory${N}"
        print "  ${D}//${N} ${C}zpwr reverse <dir>${N}     ${D}// cd up the tree to find a parent${N}"
        print "  ${D}//${N} ${C}zpwr z <pattern>${N}       ${D}// frecency-based jump (z/fasd)${N}"
        print "  ${D}//${N} ${C}zpwr home${N}              ${D}// cd to \$ZPWR${N}"
        print "  ${D}//${N} ${C}zpwr homelocal${N}         ${D}// cd to \$ZPWR_LOCAL${N}"
        print "  ${D}//${N} ${C}zpwr scripts${N}           ${D}// cd to scripts directory${N}"
        print ""
        print "  ${B}${M}Named Directories (hash -d):${N}"
        print ""
        local k v
        local -i shown=0
        for k v in ${(kv)nameddirs}; do
            (( shown >= 8 )) && break
            print "  ${D}//${N} ${C}~${k}${N}  ${D}→  ${v}${N}"
            (( shown++ ))
        done
        print "  ${D}//${N} ${D}... and $(( ${#nameddirs} - shown )) more${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Type ~ZPWR<tab> to complete named directory paths${N}"
        _wiz_footer
    }


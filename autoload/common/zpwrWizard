        print "  ${D}//${N} ${C}zpwr regenzsh${N}          ${D}// regenerate zcompdump${N}"
        print "  ${D}//${N} ${C}zpwr regenconfiglinks${N}  ${D}// relink config files${N}"
        print "  ${D}//${N} ${C}zpwr regenhistory${N}      ${D}// regenerate history file${N}"
        print "  ${D}//${N} ${C}zpwr regenenvcache${N}     ${D}// rebuild env search cache${N}"
        print ""
        print "  ${B}${M}Cleanup:${N}"
        print "  ${D}//${N} ${C}zpwr cleanall${N}          ${D}// full cleanup pass${N}"
        print "  ${D}//${N} ${C}zpwr cleandirs${N}         ${D}// remove empty directories${N}"
        print "  ${D}//${N} ${C}zpwr deduppaths${N}        ${D}// remove duplicate PATH entries${N}"
        print ""
        print "  ${B}${M}Updates:${N}"
        print "  ${D}//${N} ${C}zpwr update${N}            ${D}// pull latest zpwr + plugins${N}"
        print "  ${D}//${N} ${C}zpwr updatedeps${N}        ${D}// update all dependencies${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Run zpwr doctor after major updates to catch issues${N}"
        _wiz_footer
    }

    _wiz_page12() {
        _wiz_header "12" "THE FULL ARSENAL"
        print "  ${B}${C}${#ZPWR_VERBS} Commands at Your Fingertips:${N}"
        print ""
        print "  ${D}//${N} ${B}${#functions}${N} functions    ${D}//${N} ${B}${#_comps}${N} completions"
        print "  ${D}//${N} ${B}${#aliases}${N} aliases       ${D}//${N} ${B}${#commands}${N} commands"
        print "  ${D}//${N} ${B}${#fpath}${N} fpath entries   ${D}//${N} ${B}${#path}${N} path entries"
        print "  ${D}//${N} ${B}${#nameddirs}${N} named dirs    ${D}//${N} ${B}${#ZPWR_VARS}${N} zpwr vars"
        print ""
        print "  ${B}${M}Every new command has -h:${N}"
        print "  ${C}  zpwr bench -h${N}     ${C}zpwr top -h${N}       ${C}zpwr doctor -h${N}"
        print "  ${C}  zpwr flame -h${N}     ${C}zpwr trace -h${N}     ${C}zpwr deps -h${N}"
        print "  ${C}  zpwr funcrank -h${N}  ${C}zpwr aliasrank -h${N} ${C}zpwr watch -h${N}"
        print "  ${C}  zpwr replay -h${N}    ${C}zpwr snapshot -h${N}  ${C}zpwr restore -h${N}"
        print "  ${C}  zpwr taillog -h${N}   ${C}zpwr wizard -h${N}"
        print ""
        print "  ${B}${M}Quick Reference:${N}"
        print "  ${C}  zpwr subcommandsfzf${N}   ${D}// fzf through all verbs${N}"
        print "  ${C}  zpwr environmentcounts${N} ${D}// full env statistics${N}"
        print "  ${C}  zpwr about${N}             ${D}// the banner${N}"
        print ""
        print "  ${G}${B}You've completed the ZPWR Wizard!${N}"
        print "  ${D}  Run 'zpwr wizard' anytime to revisit.${N}"
        _wiz_footer
    }

    # ── HANDLE ARGS ───────────────────────────────────────────
    if [[ "$1" == "-t" || "$1" == "--toc" ]]; then
        _wiz_toc
        read -s -k 1 key
        [[ "$key" == [qQ] ]] && return 0
        if [[ "$key" == [0-9] ]]; then
            current_page=$key
            (( current_page < 1 )) && current_page=1
            (( current_page > total_pages )) && current_page=$total_pages
        fi
    elif [[ "$1" == <-> ]]; then
        current_page=$1
        (( current_page < 1 )) && current_page=1
        (( current_page > total_pages )) && current_page=$total_pages
    fi

    # ── MAIN LOOP ─────────────────────────────────────────────
    while true; do
        _wiz_page${current_page}

        read -s -k 1 key
        case "$key" in
            n|$'\n'|' ')
                (( current_page < total_pages )) && (( current_page++ ))
                ;;
            p)
                (( current_page > 1 )) && (( current_page-- ))
                ;;
            t)
                _wiz_toc
                read -s -k 1 key
                if [[ "$key" == [qQ] ]]; then return 0; fi
                if [[ "$key" == [0-9] ]]; then
                    current_page=$key
                    (( current_page < 1 )) && current_page=1
                    (( current_page > total_pages )) && current_page=$total_pages
                fi
                ;;
            [1-9])
                current_page=$key
                (( current_page > total_pages )) && current_page=$total_pages
                ;;
            q|Q)
                return 0
                ;;
        esac
    done
}

zpwrWizard "$@"

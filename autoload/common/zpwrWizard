        _wiz_header "3" "GIT INTEGRATION"
        print "  ${B}${C}58 Git Verbs:${N}"
        print ""
        print "  ${B}${M}Core Workflow:${N}"
        print "  ${D}//${N} ${C}zpwr gitcommit${N}         ${D}// interactive commit${N}"
        print "  ${D}//${N} ${C}zpwr gitpull${N}           ${D}// pull with rebase${N}"
        print "  ${D}//${N} ${C}zpwr gitpush${N}           ${D}// push current branch${N}"
        print "  ${D}//${N} ${C}zpwr gitstash${N}          ${D}// stash changes${N}"
        print "  ${D}//${N} ${C}zpwr gitdiff${N}           ${D}// show diff${N}"
        print ""
        print "  ${B}${M}Forgit (FZF-powered):${N}"
        print "  ${D}//${N} ${C}zpwr forgitadd${N}         ${D}// interactive stage with preview${N}"
        print "  ${D}//${N} ${C}zpwr forgitlog${N}         ${D}// visual commit log${N}"
        print "  ${D}//${N} ${C}zpwr forgitdiff${N}        ${D}// side-by-side diff${N}"
        print "  ${D}//${N} ${C}zpwr forgitstash${N}       ${D}// browse stashes${N}"
        print "  ${D}//${N} ${C}zpwr forgitcheckout${N}    ${D}// branch switcher${N}"
        print ""
        print "  ${B}${M}Batch Operations:${N}"
        print "  ${D}//${N} ${C}zpwr gitforalldir${N}      ${D}// run git command across all repos${N}"
        print "  ${D}//${N} ${C}zpwr githubcreate${N}      ${D}// create GitHub repo from cwd${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}All forgit verbs use fzf for interactive selection${N}"
        _wiz_footer
    }

    _wiz_page4() {
        _wiz_header "4" "EDITOR INTEGRATION"
        print "  ${B}${C}Vim (28 verbs) + Emacs (29 verbs):${N}"
        print ""
        print "  ${B}${M}File Operations:${N}"
        print "  ${D}//${N} ${C}zpwr vimall${N}            ${D}// open all files in fzf${N}"
        print "  ${D}//${N} ${C}zpwr vimfzf${N}            ${D}// fzf file picker → vim${N}"
        print "  ${D}//${N} ${C}zpwr vimrecent${N}         ${D}// open recent files${N}"
        print "  ${D}//${N} ${C}zpwr emacsall${N}          ${D}// same but for emacs${N}"
        print ""
        print "  ${B}${M}Search & Edit:${N}"
        print "  ${D}//${N} ${C}zpwr filesearch${N}        ${D}// find file by name → editor${N}"
        print "  ${D}//${N} ${C}zpwr wordsearch${N}        ${D}// grep for pattern → editor${N}"
        print "  ${D}//${N} ${C}zpwr dirsearch${N}         ${D}// find directory → cd${N}"
        print ""
        print "  ${B}${M}Config Files:${N}"
        print "  ${D}//${N} ${C}zpwr zrc${N}               ${D}// edit .zshrc${N}"
        print "  ${D}//${N} ${C}zpwr brc${N}               ${D}// edit aliases file${N}"
        print "  ${D}//${N} ${C}zpwr trc${N}               ${D}// edit .tmux.conf${N}"
        print "  ${D}//${N} ${C}zpwr vrc${N}               ${D}// edit .vimrc${N}"
        print "  ${D}//${N} ${C}zpwr tokens${N}            ${D}// edit personal tokens file${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Each vim verb has an emacs equivalent (replace vim→emacs)${N}"
        _wiz_footer
    }

    _wiz_page5() {
        _wiz_header "5" "SEARCH & DISCOVERY"
        print "  ${B}${C}FZF-Powered Search:${N}"
        print ""
        print "  ${D}//${N} ${C}zpwr filesearch${N}        ${D}// find files by name with fzf${N}"
        print "  ${D}//${N} ${C}zpwr wordsearch${N}        ${D}// grep contents with fzf preview${N}"
        print "  ${D}//${N} ${C}zpwr dirsearch${N}         ${D}// find and cd to directories${N}"
        print "  ${D}//${N} ${C}zpwr locate${N}            ${D}// system locate with fzf${N}"
        print "  ${D}//${N} ${C}zpwr locateedit${N}        ${D}// locate → open in editor${N}"
        print ""
        print "  ${B}${M}Completion System:${N}"
        print "  ${D}//${N} ${C}${#_comps} completions${N} loaded"
        print "  ${D}//${N} neon-coded menu groups: commands, aliases, functions, builtins"
        print "  ${D}//${N} ${C}<tab>${N} after any zpwr verb for context-aware completion"
        print ""
        print "  ${B}${M}Subcommand Discovery:${N}"
        print "  ${D}//${N} ${C}zpwr subcommands${N}       ${D}// list all ${#ZPWR_VERBS} verbs${N}"
        print "  ${D}//${N} ${C}zpwr subcommandsfzf${N}    ${D}// fzf through all verbs${N}"
        print "  ${D}//${N} ${C}zpwr subcommandslist${N}   ${D}// formatted verb list${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Type 'zpwr <tab>' to fuzzy-search all available commands${N}"
        _wiz_footer
    }

    _wiz_page6() {
        _wiz_header "6" "STARTUP PERFORMANCE"
        print "  ${B}${C}Profiling Tools:${N}"
        print ""
        print "  ${B}${M}zpwr bench [N]:${N}"
        print "  Run N shell startups, report percentiles (avg/p50/p99),"
        print "  phase breakdown, baseline comparison, persistent history."
        print "  ${C}  zpwr bench 5${N}        ${D}// 5 iterations${N}"
        print ""
        print "  ${B}${M}zpwr flame [N]:${N}"
        print "  Launch instrumented shell with zprof, render ASCII flame chart."
        print "  Heat-colored bars: ${R}▓▓▓${N} hot  ${Y}▓▓▓${N} warm  ${G}▓▓▓${N} cool  ${C}▓▓▓${N} cold"
        print "  ${C}  zpwr flame 10${N}       ${D}// top 10 hottest functions${N}"
        print ""
        print "  ${B}${M}zpwr top [interval]:${N}"
        print "  Live dashboard: memory, shell objects, modules, git,"
        print "  largest functions, PATH entries. Press q to quit."
        print "  ${C}  zpwr top 5${N}          ${D}// refresh every 5s${N}"
        print ""
        print "  ${B}${M}Current Startup:${N}"
        print "  ${D}//${N} prompt time:  ${G}${ZPWR_VARS[promptTimeMs]}s${N}"
        print "  ${D}//${N} startup time: ${G}${ZPWR_VARS[startupTimeMs]}s${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Save a baseline with zpwr bench, then check after changes${N}"
        _wiz_footer
    }

    _wiz_page7() {
        _wiz_header "7" "HEALTH & DIAGNOSTICS"
        print "  ${B}${C}Environment Scanning:${N}"
        print ""
        print "  ${B}${M}zpwr doctor:${N}"
        print "  Full health check — stale .zwc files, duplicate PATH/FPATH,"
        print "  broken symlinks, invalid named dirs, missing dependencies,"
        print "  p10k pollution, config link integrity."
        print "  ${C}  zpwr doctor${N}"
        print ""
        print "  ${B}${M}zpwr deps [function]:${N}"
        print "  Function dependency graph. What calls what, who depends on whom,"
        print "  orphan detection, graphviz export."
        print "  ${C}  zpwr deps${N}                  ${D}// summary${N}"
        print "  ${C}  zpwr deps zpwrClearList${N}     ${D}// outgoing deps${N}"
        print "  ${C}  zpwr deps -r zpwrPrettyPrint${N} ${D}// who calls this?${N}"
        print "  ${C}  zpwr deps --orphans${N}         ${D}// unused functions${N}"
        print "  ${C}  zpwr deps --dot > g.dot${N}     ${D}// graphviz export${N}"
        print ""
        print "  ${B}${M}zpwr trace <command>:${N}"
        print "  Command instrumentation: timing, resources, syscalls (Linux),"
        print "  C library calls (Linux ltrace), memory delta, signal bar."
        print "  ${C}  zpwr trace id${N}               ${D}// full trace${N}"
        print "  ${C}  zpwr trace -q make${N}           ${D}// quick mode (1 run)${N}"
        _wiz_footer
    }

    _wiz_page8() {
        _wiz_header "8" "USAGE ANALYTICS"
        print "  ${B}${C}Mine Your History:${N}"
        print ""
        print "  ${B}${M}zpwr funcrank [N]:${N}"
        print "  Rank functions by history usage. Shows top N functions,"
        print "  top zpwr verbs, never-used verbs, unused autoloads."
        print "  ${C}  zpwr funcrank${N}           ${D}// top 20${N}"
        print "  ${C}  zpwr funcrank --reset${N}   ${D}// rebuild cache${N}"
        print ""
        print "  ${B}${M}zpwr aliasrank [N]:${N}"
        print "  Rank aliases by expanded usage (reverse-matches since"
        print "  zsh-expand expands aliases before they hit history)."
        print "  Shows unused aliases and missing alias candidates."
        print "  ${C}  zpwr aliasrank${N}          ${D}// top 20${N}"
        print "  ${C}  zpwr aliasrank 50${N}       ${D}// top 50${N}"
        print ""
        print "  ${B}${M}Cache:${N}"
        print "  Both commands share a cache that rebuilds when history"
        print "  grows by 1000+ lines. Use --reset to force rebuild."
        print "  ${D}  stored in \$ZPWR_LOCAL/zpwr-{aliasrank,verbrank}-cache.zsh${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Run zpwr funcrank to discover zpwr verbs you never knew about${N}"
        _wiz_footer
    }

    _wiz_page9() {
        _wiz_header "9" "ENVIRONMENT SNAPSHOTS"
        print "  ${B}${C}Checkpoint & Restore:${N}"
        print ""
        print "  ${B}${M}zpwr snapshot [name]:${N}"
        print "  Captures: hash dirs, aliases (regular/global/suffix),"
        print "  env vars, ZPWR_VARS, shell history, dir stack, git status,"
        print "  tmux sessions/windows/panes, vim session files."
        print "  ${C}  zpwr snapshot myproject${N}     ${D}// named snapshot${N}"
        print "  ${C}  zpwr snapshot${N}               ${D}// timestamp name${N}"
        print ""
        print "  ${B}${M}zpwr restore [name] [components...]:${N}"
        print "  Selective restoration from any snapshot."
        print "  ${C}  zpwr restore${N}                    ${D}// list snapshots${N}"
        print "  ${C}  zpwr restore myproject${N}          ${D}// restore all${N}"
        print "  ${C}  zpwr restore myproject aliases${N}  ${D}// aliases only${N}"
        print ""
        print "  ${B}${M}Components:${N}"
        print "  ${C}hash${N}  ${C}aliases${N}  ${C}env${N}  ${C}tmux${N}  ${C}vim${N}  ${C}history${N}  ${C}dirs${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}Snapshot before major changes, restore if something breaks${N}"
        _wiz_footer
    }


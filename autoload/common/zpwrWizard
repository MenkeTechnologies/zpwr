        print "  ${C}  zpwr replay 5 exec${N}       ${D}// execute with timing${N}"
        print "  ${C}  zpwr replay 10 tmux${N}      ${D}// new tmux pane${N}"
        print ""
        print "  ${B}${M}zpwr taillog:${N}"
        print "  Colorized log viewer powered by ccze."
        print "  ${C}  zpwr taillog${N}             ${D}// follow with colors${N}"
        print "  ${C}  zpwr taillog -n 50${N}       ${D}// last 50 lines${N}"
        print "  ${C}  zpwr taillog -f${N}          ${D}// no follow${N}"
        print ""
        print "  ${B}${M}Tip:${N} ${D}zpwr watch + zpwr bench = continuous perf regression testing${N}"

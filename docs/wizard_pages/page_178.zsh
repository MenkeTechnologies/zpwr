    print "  ${B}${Y}THE VERB${N}"
    print "  ${M}  zpwr stale${N}${D}                 # scan and report${N}"
    print "  ${M}  zpwr stale -f${N}${D}              # delete all stale files${N}"
    print ""
    print "  ${B}${Y}WHAT IT FINDS${N}"
    print "  ${D}‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ${N}"
    print "  ${Y}  STALE .zwc${N}"
    print "  ${D}    Source file is newer than its compiled .zwc.${N}"
    print "  ${D}    Your shell is running yesterday's bytecode.${N}"
    print ""
    print "  ${R}  ORPHAN .zwc${N}"
    print "  ${D}    The source file was deleted but the .zwc remains.${N}"
    print "  ${D}    Dead weight taking up space and confusing zsh.${N}"
    print ""
    print "  ${R}  BROKEN SYMLINKS${N}"
    print "  ${D}    Symlinks pointing to files that no longer exist.${N}"
    print "  ${D}    Source of cryptic 'file not found' errors.${N}"

PAGE_TITLE="ALL Vim Visual Mode (1/1)"
PAGE_CHAPTER="APPENDIX B: COMPLETE KEYBINDING DUMP"
PAGE_CONTENT() {
    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    print "  ${B}${M}=== ALL VIM VISUAL MODE (1/1) ===${N}"
    print "  ${D}v  <Space>vl  * <Esc>:call TmuxRepeat('repl')<CR>gv${N}"
    print "  ${D}v  <Space>vk  * <Esc>:call TmuxRepeat('visual')<CR>gv${N}"
    print "  ${D}v  <Space>vj  * <Esc>:call TmuxRepeat('file')<CR>gv${N}"
    print "  ${D}v  <Space>(  * :call InsertQuoteVisualMode('paren')<CR>${N}"
    print "  ${D}v  <Space>{  * :call InsertQuoteVisualMode('curlybracket')<CR>${N}"
    print "  ${D}v  <Space>[  * :call InsertQuoteVisualMode('bracket')<CR>${N}"
    print "  ${D}v  <Space>'  * :call InsertQuoteVisualMode('back')<CR>${N}"
    print "  ${D}v  <Space>'  * :call InsertQuoteVisualMode('single')<CR<CR>${N}"
    print "  ${D}v  <Space>'  * :call InsertQuoteVisualMode('double')<CR>${N}"
    print "  ${D}v  <Space>r  * :'<,'>s@\\C\\<<C-R><C-W>\\>@<C-R><C-W>@g<Left><Left>${N}"
    print "  ${D}v  <Space>g  * :'<,'>%s@\\C\\<<C-R><C-W>\\>@@g<Left><Left>${N}"
    print "  ${D}v  <Space>b  * :w .tmux set-buffer '(cat)'<CR><CR>${N}"
    print "  ${D}v  <Space>=  * 4+${N}"
    print "  ${D}v  <Space>-  * 4-${N}"
    print "  ${D}v  <  * <gv${N}"
    print "  ${D}v  >  * >gv${N}"
    print "  ${D}v  J  * :m '> + <CR> gv${N}"
    print "  ${D}v  K  * :m '< -- <CR> gv${N}"
    print "  ${D}v  Y  * y'>j${N}"
    print "  ${D}v  \\K  * y:Thesaurus <C-R>'<CR>${N}"
    print "  ${D}v  go  * :call CopyClip()<CR> :call system('bash ZPWR_TMUX/google.sh open'${N}"
    print "  ${D}v  gs  * :call CopyClip()<CR> :call system('bash ZPWR_TMUX/google.sh googl${N}"
    print "  ${D}v  <C-D>d  * :<C-C>:update<CR>${N}"
    print "  ${D}v  <C-D>y  * :<C-C>:update<CR>:SyntasticCheck<CR>${N}"
    print "  ${D}v  <C-D>,  * :call NERDComment('x','Toggle')<CR>'>${N}"
    print "  ${D}v  <RightMouse> * :call CopyClip()<CR>'>${N}"
    print "  ${D}v  <C-B>  * :call CopyClip()<CR>'>${N}"
    print "  ${D}v  <C-Up>  * :m '< -- <CR> gv${N}"
    print "  ${D}v  <C-Down>  * :m '> + <CR> gv${N}"
    print "  ${D}v  <C-Left>  * <gv${N}"
    print "  ${D}v  <C-Right>  * >gv${N}"
    print "  ${D}v  <C-F>  * :<C-C>:q.<CR>${N}"
    print "  ${D}v  <C-L>  * 4l${N}"
    print "  ${D}v  <C-K>  * 4k${N}"
    print "  ${D}v  <C-J>  * 4j${N}"
    print "  ${D}v  <D-x>  '*d${N}"
    print "  ${D}v  <D-c>  '*y${N}"
    print "  ${D}v  <D-v>  '-d'*P${N}"
}

PAGE_TITLE="ALL Vim Normal Mode (2/3)"
PAGE_CHAPTER="APPENDIX B: COMPLETE KEYBINDING DUMP"
PAGE_CONTENT() {
    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    print "  ${B}${M}=== ALL VIM NORMAL MODE (2/3) ===${N}"
    print "  ${D}n  <Space>s  * :split<CR>${N}"
    print "  ${D}n  <Space>v  * :vsplit<CR>${N}"
    print "  ${D}n  <Space>w  * :w.<CR>${N}"
    print "  ${D}n  <Space>e  * :q.<CR>${N}"
    print "  ${D}n  <Space>wq  * :wq.<CR>${N}"
    print "  ${D}n  <Space>q  * :qa.<CR>${N}"
    print "  ${D}n  <Space>r  * :%s@\\C\\<<C-R><C-W>\\>@<C-R><C-W>@g<Left><Left>${N}"
    print "  ${D}n  <Space>g  * :%s@\\C\\<<C-R><C-W>\\>@@g<Left><Left>${N}"
    print "  ${D}n  <Space>=  * 4+${N}"
    print "  ${D}n  <Space>-  * 4-${N}"
    print "  ${D}n  &&  * :normal mzg&'zzz<CR>${N}"
    print "  ${D}n  &  * :&&<CR>${N}"
    print "  ${D}n  <s<Esc>  & <Nop>${N}"
    print "  ${D}n  =s<Esc>  & <Nop>${N}"
    print "  ${D}n  >s<Esc>  & <Nop>${N}"
    print "  ${D}n  N  * :call GoToLastSearch('?')<CR>${N}"
    print "  ${D}n  Y  * yy'>${N}"
    print "  ${D}n  [o<Esc>  & <Nop>${N}"
    print "  ${D}n  []  k][%?}<CR>]}]]}]]${N}"
    print "  ${D}n  [[  ?{<CR>w99[{${N}"
    print "  ${D}n  \\K  * :OnlineThesaurusCurrentWord<CR>${N}"
    print "  ${D}n  ]o<Esc>  & <Nop>${N}"
    print "  ${D}n  ]]  j0[[%/{<CR>${N}"
    print "  ${D}n  ][  /}<CR>b99]}${N}"
    print "  ${D}n  n  * :call GoToLastSearch('/')<CR>${N}"
    print "  ${D}n  yo<Esc>  & <Nop>${N}"
    print "  ${D}n  y<C-G>  & :<C-U>call setreg(v:register, fugitive#Object(@%))<CR>${N}"
    print "  ${D}n  z/  * :if AutoHighlightToggle()|set hls|endif<CR>${N}"
    print "  ${D}n  <SNR>198_:  * :<C-U><C-R>=v:count ? v:count : ''<CR>${N}"
    print "  ${D}n  <C-G>  * :call multiple_cursors#new('n', 1)<CR>${N}"
    print "  ${D}n  <F11>  * :call conque_term#exec_file()<CR>${N}"
    print "  ${D}n  <C-W>\\  * :vsplit<CR>${N}"
    print "  ${D}n  <C-W>-  * :split<CR>${N}"
    print "  ${D}n  <C-D>,  * :FZFEnv<CR>${N}"
    print "  ${D}n  <C-D>.  * :FZFKeys<CR>${N}"
    print "  ${D}n  <C-D>/  * :LocateAll<CR>${N}"
    print "  ${D}n  <C-D>z  * :TlistAddFiles *<CR>:TlistToggle<CR>${N}"
    print "  ${D}n  <C-D>y  * :update<CR>:SyntasticCheck<CR>${N}"
    print "  ${D}n  <C-D>x  * :Marks<CR>${N}"
    print "  ${D}n  <C-D>w  * :update<CR>${N}"
    print "  ${D}n  <C-D>v  * :w.<CR>:call TmuxRepeatGeneric()<CR>${N}"
    print "  ${D}n  <C-D>u  * :History:<CR>${N}"
    print "  ${D}n  <C-D>]  * <C-W>}<CR>${N}"
    print "  ${D}n  <C-D>t  * :Tags<CR>${N}"
    print "  ${D}n  <C-D>s  * :History/<CR>${N}"
    print "  ${D}n  <C-D>rr  * :Rg<CR>${N}"
    print "  ${D}n  <C-D>rq  * :silent .open -t %:p:h<CR>:redraw.<CR>${N}"
    print "  ${D}n  <C-D>q  * :SaveSession.<CR><Tab>${N}"
}

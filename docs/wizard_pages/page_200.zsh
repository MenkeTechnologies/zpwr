PAGE_TITLE="ALL Tmux Prefix Keys (1/4)"
PAGE_CHAPTER="APPENDIX B: COMPLETE KEYBINDING DUMP"
PAGE_CONTENT() {
    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    print "  ${B}${M}=== ALL TMUX PREFIX KEYS (1/4) ===${N}"
    print "  ${D}bind-key  -T prefix  Space  run-shell -b 'ZPWR/scripts/allPanes.zsh single${N}"
    print "  ${D}bind-key  -T prefix  .  break-pane${N}"
    print "  ${D}bind-key  -T prefix  \\'  split-window${N}"
    print "  ${D}bind-key  -T prefix  \\#  list-buffers${N}"
    print "  ${D}bind-key  -T prefix  \\  command-prompt -I '#S' { rename-session '%%' }${N}"
    print "  ${D}bind-key  -T prefix  \\%  split-window -h${N}"
    print "  ${D}bind-key  -T prefix  &  confirm-before -p 'kill-window #W? (y/n)' kill-win${N}"
    print "  ${D}bind-key  -T prefix  \\'  command-prompt -T window-target -p index { selec${N}"
    print "  ${D}bind-key -r -T prefix  (  switch-client -p${N}"
    print "  ${D}bind-key -r -T prefix  )  switch-client -n${N}"
    print "  ${D}bind-key  -T prefix  +  split-window -v -c '#{pane_current_path}' \\; sele${N}"
    print "  ${D}bind-key  -T prefix  ,  command-prompt -I '#W' { rename-window '%%' }${N}"
    print "  ${D}bind-key  -T prefix  -  split-window -v -c '#{pane_current_path}'${N}"
    print "  ${D}bind-key  -T prefix  .  command-prompt -T target { move-window -t '%%' }${N}"
    print "  ${D}bind-key  -T prefix  /  command-prompt -k -p key { list-keys -1N '%%' }${N}"
    print "  ${D}bind-key  -T prefix  0  select-window -t :=0${N}"
    print "  ${D}bind-key  -T prefix  1  select-window -t :=1${N}"
    print "  ${D}bind-key  -T prefix  2  select-window -t :=2${N}"
    print "  ${D}bind-key  -T prefix  3  select-window -t :=3${N}"
    print "  ${D}bind-key  -T prefix  4  select-window -t :=4${N}"
    print "  ${D}bind-key  -T prefix  5  select-window -t :=5${N}"
    print "  ${D}bind-key  -T prefix  6  select-window -t :=6${N}"
    print "  ${D}bind-key  -T prefix  7  select-window -t :=7${N}"
    print "  ${D}bind-key  -T prefix  8  select-window -t :=8${N}"
    print "  ${D}bind-key  -T prefix  9  select-window -t :=9${N}"
    print "  ${D}bind-key  -T prefix  :  command-prompt${N}"
    print "  ${D}bind-key  -T prefix  \\;  last-pane${N}"
    print "  ${D}bind-key  -T prefix  <  display-menu -T '#[align=centre]#{window_index}:#{${N}"
    print "  ${D}bind-key  -T prefix  =  choose-buffer -Z${N}"
    print "  ${D}bind-key  -T prefix  >  display-menu -T '#[align=centre]#{pane_index} (#{p${N}"
    print "  ${D}bind-key  -T prefix  ?  list-keys -N${N}"
    print "  ${D}bind-key  -T prefix  C  customize-mode -Z${N}"
    print "  ${D}bind-key  -T prefix  D  source-file ZPWR/tmux/control-window.conf${N}"
    print "  ${D}bind-key  -T prefix  E  source-file ZPWR/tmux/fourVertical.conf${N}"
    print "  ${D}bind-key  -T prefix  F  source-file ZPWR/tmux/four-panes.conf${N}"
    print "  ${D}bind-key  -T prefix  G  source-file ZPWR/tmux/eight-panes.conf${N}"
    print "  ${D}bind-key -r -T prefix  H  resize-pane -L 5${N}"
    print "  ${D}bind-key  -T prefix  I  run-shell HOME/.tmux/plugins/tpm/bindings/install_${N}"
    print "  ${D}bind-key -r -T prefix  J  resize-pane -D 5${N}"
    print "  ${D}bind-key -r -T prefix  K  resize-pane -U 5${N}"
    print "  ${D}bind-key -r -T prefix  L  resize-pane -R 5${N}"
    print "  ${D}bind-key  -T prefix  M  source-file ZPWR/tmux/learn.conf${N}"
    print "  ${D}bind-key  -T prefix  O  source-file ZPWR/tmux/sixteen-panes.conf${N}"
    print "  ${D}bind-key  -T prefix  P  paste-buffer${N}"
    print "  ${D}bind-key  -T prefix  R  source-file ZPWR/tmux/thirtytwo-panes-repl.conf${N}"
    print "  ${D}bind-key  -T prefix  S  set-window-option synchronize-panes${N}"
    print "  ${D}bind-key  -T prefix  T  source-file ZPWR/tmux/config-files.conf${N}"
    print "  ${D}bind-key  -T prefix  U  run-shell HOME/.tmux/plugins/tpm/bindings/update_p${N}"
}

PAGE_TITLE="ALL Zsh Visual Mode (2/2)"
PAGE_CHAPTER="APPENDIX B: COMPLETE KEYBINDING DUMP"
PAGE_CONTENT() {
    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    print "  ${B}${M}=== ALL ZSH VISUAL MODE (2/2) ===${N}"
    print "  ${D}bindkey -M visual 'i=' select-quoted${N}"
    print "  ${D}bindkey -M visual 'i>' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'i@' select-quoted${N}"
    print "  ${D}bindkey -M visual 'iB' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'iW' select-in-blank-word${N}"
    print "  ${D}bindkey -M visual 'i[' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'i\\\\\\\\' select-quoted${N}"
    print "  ${D}bindkey -M visual 'i]' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'i\\'' select-quoted${N}"
    print "  ${D}bindkey -M visual 'ia' select-in-shell-word${N}"
    print "  ${D}bindkey -M visual 'ib' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'iw' select-in-word${N}"
    print "  ${D}bindkey -M visual 'i{' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'i|' select-quoted${N}"
    print "  ${D}bindkey -M visual 'i}' select-bracketed${N}"
    print "  ${D}bindkey -M visual 'j' down-line${N}"
    print "  ${D}bindkey -M visual 'k' up-line${N}"
    print "  ${D}bindkey -M visual 'o' exchange-point-and-mark${N}"
    print "  ${D}bindkey -M visual 'p' put-replace-selection${N}"
    print "  ${D}bindkey -M visual 'u' vi-down-case${N}"
    print "  ${D}bindkey -M visual 'x' vi-delete${N}"
    print "  ${D}bindkey -M visual '~' vi-oper-swap-case${N}"
}

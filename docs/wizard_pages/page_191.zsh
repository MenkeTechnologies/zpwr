PAGE_TITLE="ALL Tmux Prefix Keys (2/4)"
PAGE_CHAPTER="APPENDIX B: COMPLETE KEYBINDING DUMP"
PAGE_CONTENT() {
    local C=$'\033[36m' G=$'\033[32m' Y=$'\033[33m' R=$'\033[31m'
    local M=$'\033[35m' B=$'\033[1m' D=$'\033[2m' N=$'\033[0m'
    print "  ${B}${M}=== ALL TMUX PREFIX KEYS (2/4) ===${N}"
    print "  ${D}bind-key  -T prefix  Y  split-window -v -c '#{pane_current_path}' \\; sele${N}"
    print "  ${D}bind-key  -T prefix  [  copy-mode${N}"
    print "  ${D}bind-key  -T prefix  \\\\  split-window -h -c '#{pane_current_path}'${N}"
    print "  ${D}bind-key  -T prefix  ]  paste-buffer -p${N}"
    print "  ${D}bind-key  -T prefix  _  split-window -v${N}"
    print "  ${D}bind-key  -T prefix  a  last-window${N}"
    print "  ${D}bind-key  -T prefix  b  run-shell -b 'ZPWR/scripts/allPanes.zsh single ope${N}"
    print "  ${D}bind-key  -T prefix  c  new-window${N}"
    print "  ${D}bind-key  -T prefix  d  detach-client${N}"
    print "  ${D}bind-key  -T prefix  e  run-shell -b 'HOME/.tmux/plugins/tmux-fzf-url/fzf-${N}"
    print "  ${D}bind-key  -T prefix  f  command-prompt { find-window -Z '%%' }${N}"
    print "  ${D}bind-key  -T prefix  g  run-shell -b 'ZPWR/scripts/allPanes.zsh single goo${N}"
    print "  ${D}bind-key -r -T prefix  h  select-pane -L${N}"
    print "  ${D}bind-key  -T prefix  i  display-message${N}"
    print "  ${D}bind-key -r -T prefix  j  select-pane -D${N}"
    print "  ${D}bind-key -r -T prefix  k  select-pane -U${N}"
    print "  ${D}bind-key -r -T prefix  l  select-pane -R${N}"
    print "  ${D}bind-key  -T prefix  m  select-pane -m${N}"
    print "  ${D}bind-key -r -T prefix  n  next-window${N}"
    print "  ${D}bind-key  -T prefix  o  select-pane -t :.+${N}"
    print "  ${D}bind-key -r -T prefix  p  previous-window${N}"
    print "  ${D}bind-key  -T prefix  q  display-panes -d 5000${N}"
    print "  ${D}bind-key  -T prefix  r  source-file ZPWR/tmux/init.conf \\; display-messag${N}"
    print "  ${D}bind-key  -T prefix  s  choose-tree -Zs${N}"
    print "  ${D}bind-key  -T prefix  t  clock-mode${N}"
    print "  ${D}bind-key  -T prefix  u  run-shell -b 'HOME/.tmux/plugins/tmux-fzf-url/fzf-${N}"
    print "  ${D}bind-key  -T prefix  v  run-shell -b 'ZPWR/scripts/allPanes.zsh multi'${N}"
    print "  ${D}bind-key  -T prefix  w  choose-tree -Zw${N}"
    print "  ${D}bind-key  -T prefix  x  kill-pane${N}"
    print "  ${D}bind-key  -T prefix  z  resize-pane -Z${N}"
    print "  ${D}bind-key -r -T prefix  \\{  rotate-window${N}"
    print "  ${D}bind-key  -T prefix  |  split-window -h${N}"
    print "  ${D}bind-key  -T prefix  \\}  swap-pane -D${N}"
    print "  ${D}bind-key  -T prefix  \\~  show-messages${N}"
    print "  ${D}bind-key -r -T prefix  DC  refresh-client -c${N}"
    print "  ${D}bind-key  -T prefix  PPage  copy-mode -u${N}"
    print "  ${D}bind-key -r -T prefix  Up  select-pane -U${N}"
    print "  ${D}bind-key -r -T prefix  Down  select-pane -D${N}"
    print "  ${D}bind-key -r -T prefix  Left  select-pane -L${N}"
    print "  ${D}bind-key -r -T prefix  Right  select-pane -R${N}"
    print "  ${D}bind-key  -T prefix  M-1  select-layout even-horizontal${N}"
    print "  ${D}bind-key  -T prefix  M-2  select-layout even-vertical${N}"
    print "  ${D}bind-key  -T prefix  M-3  select-layout main-horizontal${N}"
    print "  ${D}bind-key  -T prefix  M-4  select-layout main-vertical${N}"
    print "  ${D}bind-key  -T prefix  M-5  select-layout tiled${N}"
    print "  ${D}bind-key  -T prefix  M-6  select-layout main-horizontal-mirrored${N}"
    print "  ${D}bind-key  -T prefix  M-7  select-layout main-vertical-mirrored${N}"
    print "  ${D}bind-key  -T prefix  M-n  next-window -a${N}"
}
